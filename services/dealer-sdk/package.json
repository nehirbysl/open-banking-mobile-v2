{
  "name": "@bankdhofar/auto-loans-sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for Bank Dhofar Open Finance — Auto Loan Origination APIs (TPP-side)",
  "license": "Proprietary — Bank Dhofar Auto-Lending TPP Agreement",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.5",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "publishConfig": {
    "registry": "https://gitlab.bankdhofar.com/api/v4/projects/ea%2Fopen-banking/packages/npm/"
  },
  "keywords": ["bank-dhofar", "open-banking", "open-finance", "auto-loan", "embedded-lending", "oman"],
  "engines": {
    "node": ">=18"
  }
}
