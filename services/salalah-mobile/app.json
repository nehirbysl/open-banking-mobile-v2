{
  "expo": {
    "name": "Salalah Souq",
    "slug": "salalah-mobile",
    "scheme": "salalahsouq",
    "version": "1.0.2",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#D35400",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "com.bankdhofar.salalahsouq",
      "supportsTablet": true,
      "buildNumber": "10",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["bdonline"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bankdhofar.salalahsouq",
      "adaptiveIcon": {
        "backgroundColor": "#D35400"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
